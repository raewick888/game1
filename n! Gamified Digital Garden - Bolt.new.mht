.no-scrollbar { scrollbar-width: none; }

.scrollbar-gutter-stable { scrollbar-gutter: stable; }

.container { width: 100%; }

.no-scrollbar::-webkit-scrollbar { display: none; }

.dot { width: 0.25rem; height: 0.25rem; border-radius: 9999px; background-color: var(--bolt-ds-textSecondary); }

.max-w-chat { max-width: var(--chat-max-width); }

.transition-theme { transition-property: background-color, border-color, color, opacity; transition-duration: 0.15s; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); }

.bolt-ease-cubic-bezier { transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); }

